/* ─── PENTEST CHECKLIST ─── */
function PentestChecklist() {
  const [phases, setPhases] = useState(PENTEST_PHASES);
  const [expandedPhase, setExpandedPhase] = useState(0);

  const toggle = (phaseIdx, itemId) => {
    setPhases((prev) =>
      prev.map((p, pi) =>
        pi === phaseIdx
          ? { ...p, items: p.items.map((it) => (it.id === itemId ? { ...it, done: !it.done } : it)) }
          : p
      )
    );
  };

  const totalDone = phases.reduce((a, p) => a + p.items.filter((i) => i.done).length, 0);
  const totalItems = phases.reduce((a, p) => a + p.items.length, 0);
  const pct = Math.round((totalDone / totalItems) * 100);

  return (
    <GlassCard glow="#00d4ff">
      <div className="px-5 py-3.5 border-b" style={{ borderColor: "rgba(0,212,255,0.06)" }}>
        <div className="flex items-center justify-between mb-3">
          <div className="flex items-center gap-2.5">
            <CheckSquare size={16} style={{ color: "#00d4ff" }} />
            <span style={{ fontFamily: "'JetBrains Mono', monospace", color: "#e2e8f0", fontSize: 13, fontWeight: 600 }}>
              PENTEST CHECKLIST
            </span>
          </div>
          <span className="text-xs font-mono" style={{ color: "#00d4ff" }}>{totalDone}/{totalItems}</span>
        </div>
        <div className="relative h-2 rounded-full overflow-hidden" style={{ background: "rgba(0,212,255,0.08)" }}>
          <motion.div animate={{ width: `${pct}%` }} transition={{ duration: 0.6, ease: "easeOut" }}
            className="absolute inset-y-0 left-0 rounded-full"
            style={{ background: "linear-gradient(90deg, #00d4ff, #00ffc8)", boxShadow: "0 0 12px rgba(0,212,255,0.4)" }} />
        </div>
        <div className="text-right mt-1">
          <span className="text-[10px] font-mono" style={{ color: "#475569" }}>{pct}% complete</span>
        </div>
      </div>

      <div className="divide-y" style={{ divideColor: "rgba(255,255,255,0.03)" }}>
        {phases.map((phase, pi) => {
          const phaseDone = phase.items.filter((i) => i.done).length;
          const isOpen = expandedPhase === pi;
          return (
            <div key={phase.phase}>
              <button onClick={() => setExpandedPhase(isOpen ? -1 : pi)}
                className="w-full px-5 py-3 flex items-center gap-3 hover:bg-white/[0.02] transition-colors">
                <div className="p-1.5 rounded-lg" style={{ background: `${phase.color}12` }}>
                  <phase.icon size={14} style={{ color: phase.color }} />
                </div>
                <span className="flex-1 text-left text-xs font-semibold" style={{ color: "#e2e8f0", fontFamily: "'JetBrains Mono', monospace" }}>
                  {phase.phase}
                </span>
                <span className="text-[10px] font-mono mr-2" style={{ color: phase.color }}>{phaseDone}/{phase.items.length}</span>
                <motion.div animate={{ rotate: isOpen ? 90 : 0 }}>
                  <ChevronRight size={14} style={{ color: "#475569" }} />
                </motion.div>
              </button>
              <AnimatePresence>
                {isOpen && (
                  <motion.div initial={{ height: 0, opacity: 0 }} animate={{ height: "auto", opacity: 1 }} exit={{ height: 0, opacity: 0 }}
                    transition={{ duration: 0.3 }} className="overflow-hidden">
                    <div className="px-5 pb-3 space-y-1">
                      {phase.items.map((item) => (
                        <motion.button key={item.id} whileTap={{ scale: 0.98 }}
                          onClick={() => toggle(pi, item.id)}
                          className="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left hover:bg-white/[0.02] transition-colors group"
                        >
                          <div className="w-4 h-4 rounded border flex items-center justify-center flex-shrink-0 transition-all"
                            style={{
                              borderColor: item.done ? phase.color : "#334155",
                              background: item.done ? `${phase.color}20` : "transparent",
                            }}>
                            {item.done && <Check size={10} style={{ color: phase.color }} />}
                          </div>
                          <span className="text-xs transition-all"
                            style={{
                              color: item.done ? "#475569" : "#94a3b8",
                              textDecoration: item.done ? "line-through" : "none",
                              fontFamily: "'JetBrains Mono', monospace", fontSize: 11,
                            }}>
                            {item.text}
                          </span>
                        </motion.button>
                      ))}
                    </div>
                  </motion.div>
                )}
              </AnimatePresence>
            </div>
          );
        })}
      </div>
    </GlassCard>
  );
}

