/* ─── TOOL GRID ─── */
function ToolGrid({ searchQuery }) {
  const filtered = TOOLS.filter(
    (t) =>
      t.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
      t.category.toLowerCase().includes(searchQuery.toLowerCase()) ||
      t.desc.toLowerCase().includes(searchQuery.toLowerCase())
  );
  return (
    <div>
      <div className="flex items-center gap-2.5 mb-4">
        <BookOpen size={16} style={{ color: "#00ffc8" }} />
        <span style={{ fontFamily: "'JetBrains Mono', monospace", color: "#e2e8f0", fontSize: 13, fontWeight: 600 }}>
          TOOL REFERENCE
        </span>
      </div>
      <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
        {filtered.map((tool, i) => (
          <ToolCard key={tool.name} tool={tool} index={i} />
        ))}
      </div>
    </div>
  );
}

/* ─── TERMINAL ─── */
function TerminalUI() {
  const [logs, setLogs] = useState(TERMINAL_LOGS);
  const [input, setInput] = useState("");
  const scrollRef = useRef(null);

  useEffect(() => {
    if (scrollRef.current) scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
  }, [logs]);

  const typeColor = (t) =>
    t === "success" ? "#00ffc8" : t === "warning" ? "#ffcc00" : t === "error" ? "#ff3366" : "#64748b";

  const handleSubmit = () => {
    if (!input.trim()) return;
    const now = new Date();
    const time = `${String(now.getHours()).padStart(2, "0")}:${String(now.getMinutes()).padStart(2, "0")}:${String(now.getSeconds()).padStart(2, "0")}`;
    setLogs((prev) => [...prev, { time, type: "info", msg: `$ ${input}` }]);
    setInput("");
  };

  return (
    <GlassCard glow="#00ffc8" className="flex flex-col" style={{ height: 340 }}>
      <div className="flex items-center gap-2 px-4 py-2.5 border-b" style={{ borderColor: "rgba(0,255,200,0.06)" }}>
        <div className="flex gap-1.5">
          <span className="w-3 h-3 rounded-full" style={{ background: "#ff5f57" }} />
          <span className="w-3 h-3 rounded-full" style={{ background: "#febc2e" }} />
          <span className="w-3 h-3 rounded-full" style={{ background: "#28c840" }} />
        </div>
        <span className="flex-1 text-center text-[10px]" style={{ color: "#475569", fontFamily: "'JetBrains Mono', monospace" }}>
          hunter@cyberhub:~
        </span>
      </div>
      <div ref={scrollRef} className="flex-1 overflow-y-auto px-4 py-3 space-y-1"
        style={{ scrollbarWidth: "none" }}>
        {logs.map((log, i) => (
          <motion.div key={i} initial={{ opacity: 0, x: -10 }} animate={{ opacity: 1, x: 0 }} transition={{ delay: i * 0.03 }}
            className="flex items-start gap-2">
            <span className="flex-shrink-0 text-[10px]" style={{ color: "#334155", fontFamily: "'JetBrains Mono', monospace" }}>
              {log.time}
            </span>
            <span className="text-[11px]" style={{ color: typeColor(log.type), fontFamily: "'JetBrains Mono', monospace" }}>
              {log.msg}
            </span>
          </motion.div>
        ))}
      </div>
      <div className="flex items-center gap-2 px-4 py-2.5 border-t" style={{ borderColor: "rgba(0,255,200,0.06)" }}>
        <span style={{ color: "#00ffc8", fontFamily: "'JetBrains Mono', monospace", fontSize: 12 }}>$</span>
        <input
          value={input} onChange={(e) => setInput(e.target.value)}
          onKeyDown={(e) => e.key === "Enter" && handleSubmit()}
          placeholder="Type a note or command..."
          className="flex-1 bg-transparent outline-none text-xs"
          style={{ color: "#e2e8f0", fontFamily: "'JetBrains Mono', monospace", fontSize: 11, caretColor: "#00ffc8" }}
        />
        <motion.button whileHover={{ scale: 1.1 }} whileTap={{ scale: 0.9 }} onClick={handleSubmit}
          className="p-1 rounded hover:bg-white/5">
          <Send size={12} style={{ color: "#00ffc8" }} />
        </motion.button>
      </div>
    </GlassCard>
  );
}

